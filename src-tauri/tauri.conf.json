{
  "version": "1.0.3",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "Bluelayer desktop client.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources"
    ],
    "publisher": "Bluelayer",
    "externalBin": [
      "sidecar/bluelayer-mihomo",
      "sidecar/bluelayer-mihomo-alpha"
    ],
    "copyright": "GNU General Public License v3.0",
    "category": "DeveloperTool",
    "shortDescription": "Bluelayer desktop client.",
    "createUpdaterArtifacts": false
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3000/",
    "removeUnusedCommands": true
  },
  "productName": "Bluelayer",
  "mainBinaryName": "bluelayer",
  "identifier": "uk.bluelayer.client",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyOEMyRjBCQkVGOUJEREYKUldUZnZmbStDeStNMHU5Mmo1N24xQXZwSVRYbXA2NUpzZE5oVzlqeS9Bc0t6RVV4MmtwVjBZaHgK",
      "endpoints": [],
      "windows": {
        "installMode": "passive"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "clash",
          "clash-verge"
        ]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": [
        "desktop-capability",
        "migrated"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  }
}
