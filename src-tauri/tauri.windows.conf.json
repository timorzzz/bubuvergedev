{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "identifier": "uk.bluelayer.client",
  "bundle": {
    "targets": [
      "nsis"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "languages": [
          "SimpChinese",
          "English",
          "Russian"
        ],
        "installMode": "perMachine",
        "template": "./packages/windows/installer.nsi"
      }
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Bluelayer 加速器",
        "width": 800,
        "height": 580,
        "minWidth": 800,
        "minHeight": 580,
        "maxWidth": 800,
        "maxHeight": 580,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "capabilities": [
        "desktop-capability",
        "desktop-windows-capability",
        "migrated"
      ]
    }
  }
}
